type RealArray = array_dv[real];

function VectorAdd_CPU(A, B : RealArray returns RealArray)
let 
  N := array_size(A)
in
  for I in 1, N
    Val := A[I] + B[I]
  returns array_dv of Val
end for
end function

function VectorAdd_GPU(A, B : RealArray returns RealArray)
let 
  N := array_size(A)
in
  for I in 1, N
    Val := A[I] + B[I]
  returns array_dv of Val
end for
end function
