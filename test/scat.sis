define main

type twoi = array[array[integer]];
type twod = array[array[double_real]];

function scatter( l,k:integer; mask:twoi; A:twod returns Twod )
  for i in 1,l cross j in 1,k 
    v := if ( mask[i,k] = 1 ) then 0.0D0 else A[i,k] end if;
  returns array of v
  end for
end function

function main( nlop,l,k:integer; returns twod )
let
  mat  := for i in 1,l cross j in 1,k returns array of 1.0D0 end for;
  mask := for i in 1,l cross j in 1,k returns array of mod(i+j,3) end for;
in
  for initial
    M := mat;
    i := 1;
  while ( i <= nlop ) repeat
    i := old i + 1;
    M := scatter( l,k, mask, old M );
  returns value of M
  end for
end let
end function


