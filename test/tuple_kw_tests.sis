define tuple_kw_tests,
  tuple_kw_swap,
  tuple_kw_typed,
  tuple_kw_chain

% Test 4: tuple keyword — value expression and destructuring
function tuple_kw_swap( a : integer; b : integer returns integer, integer )
  let tuple(x, y) := tuple(b, a) in
  x, y
end function

% Test 5: tuple keyword — typed destructuring
function tuple_kw_typed( a : integer; b : integer returns integer, integer )
  let tuple(x, y) : tuple(integer, integer) := tuple(a + 1, b + 1) in
  x, y
end function

% Test 6: tuple keyword — chained bindings
function tuple_kw_chain( a : integer; b : integer; c : integer returns integer )
  let tuple(s, d) := tuple(a + b, a - b) in
  let result := s + c in
  result
end function
