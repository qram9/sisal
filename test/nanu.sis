%
% A is an input matrix of NxN double_real floating point numbers.  B
% is a matrix of NxN double_real floating point numbers.  The  program
% returns the solution set C of A * B = C. If A is singular an error
% value is NOT generated.
%
%
 
define Main
 
%type double = real;
type Onei   = array[integer];
type Oned   = array[real];
type Twod   = array[Oned];
 
% global rand (returns integer)
 
function Be(n,s:integer returns Oned)
    for i in 1, n
%       returns array of real( rand()/(i-10) )
        returns array of real(s*i/if((i-10)=0) then 1 else (i-10) end if)
    end for
end function
 
 
function Setupa(n:integer returns Twod)

 
	for E in  array_fill(1,n,array_fill(1,n,0.0)) at I,J 
	returns
		array of 
		if (I=J)
		then 1.0
		else 0.0
		end if
       end for
  end function
 
function Setupb(n,s:integer returns Twod)
      for E in array_fill(1,n,Be(n,s))
      returns
         array of E
       end for
end function
 
function Compute(n,I,K: integer; Ain: TwoD; Bin: TwoD
                 returns  real)

       for j in 1,n
          returns value of sum  Ain[I,J] * Bin[J,K]
       end for
 
 
end function
 
 
function GetC(n: integer; A , B : Twod   returns Twod)
 
   let
     Ce := array_fill(1,n,0.0);
     C  := array_fill(1,n,Ce)
   in
     for X in C at I,K
 
     returns
        array of compute(n,I,K,A,B)
     end for
   end let
 end function
 
 
function Main(n: integer   returns integer)
    let
        A  := Setupa(n);
        B := Setupb(n,5);
        C := GetC(n,A , B)
     in
        for X in C  at i,j 
	ncnt:integer := (if (C[i,j]=B[i,j]) then 0 else 1 end if)
        returns value of  sum ncnt
        end for
    end let
 end function


