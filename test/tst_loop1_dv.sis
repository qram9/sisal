% Hydro Fragment
% Parallel Algorithm
% DV variant: returns array[..] of signals monolithic pre-allocated output
% Note: return type mismatch expected until Array_dv type syntax is added

Define  Main

%type double = double_real;
type OneD   = array[double];

function Main( n:integer; Q,R,T:double; Y,Z:OneD returns OneD )
   for K in Y
       X := K+K
   returns array[..] of X
   end for
end function
