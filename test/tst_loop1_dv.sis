% Hydro Fragment
% Parallel Algorithm
% DV variant: returns array[..] of signals monolithic pre-allocated output
Define  Main

%type double = double_real;
type OneD   = array[double];
type OneDV  = array_dv[double];

function Main( n:integer; Q,R,T:double; Y,Z:OneD returns OneDV )
   for K in Y
       X := K+K
   returns array[..] of X
   end for
end function
