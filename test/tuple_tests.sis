define tuple_tests,
  tuple_swap,
  tuple_typed,
  tuple_sum3,
  tuple_kw_swap,
  tuple_kw_typed,
  tuple_kw_chain

% Test 1: Basic tuple destructuring using #() syntax
function tuple_swap( a : integer; b : integer returns integer, integer )
  let #(x, y) := #(b, a) in
  x, y
end function

% Test 2: Typed tuple destructuring using #() syntax
function tuple_typed( a : integer; b : integer returns integer, integer )
  let #(x, y) : #(integer, integer) := #(a + 1, b + 1) in
  x, y
end function

% Test 3: Chained tuple let bindings with #() syntax
function tuple_sum3( a : integer; b : integer; c : integer returns integer )
  let #(s, d) := #(a + b, a - b) in
  let result := s + c in
  result
end function

% Test 4: tuple keyword — value expression and destructuring
function tuple_kw_swap( a : integer; b : integer returns integer, integer )
  let tuple(x, y) := tuple(b, a) in
  x, y
end function

% Test 5: tuple keyword — typed destructuring
function tuple_kw_typed( a : integer; b : integer returns integer, integer )
  let tuple(x, y) : tuple(integer, integer) := tuple(a + 1, b + 1) in
  x, y
end function

% Test 6: tuple keyword — chained bindings
function tuple_kw_chain( a : integer; b : integer; c : integer returns integer )
  let tuple(s, d) := tuple(a + b, a - b) in
  let result := s + c in
  result
end function
