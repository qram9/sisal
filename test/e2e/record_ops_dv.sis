% record ops: nested BY-VALUE records (Inner inside Pair -- struct emission
% must be topological), chained field reads, functional replace
define main
type Inner = record[ x: integer; y: integer ];
type Pair  = record[ a: integer; n: Inner ];
function main( returns integer, integer, integer )
  let p := record Pair [a: 7; n: record Inner [x: 1; y: 2]];
      q := p replace [a: 40]
  in p.a + q.a, p.n.x + p.n.y, q.n.y
  end let
end function
