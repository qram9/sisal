% forall_rowscatter_dv.sis -- forall scatter of WHOLE ARRAYS: the element's
% dims become the TAIL of the shape at its slot (one memcpy per iteration,
% element size/rank read off its dope at runtime).  Rows land reversed.
define main
type OneD = array_dv[integer];
function row( k: integer returns OneD )
  for j in 1, 4 returns array_dv of j * k end for
end function
function main( returns OneD )
  for i in 1, 3
  returns array_dv(3) of row(i) at [4 - i]
  end for
end function
