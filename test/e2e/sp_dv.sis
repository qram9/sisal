% Sparse matrix-vector multiply — DV variant (based on sp.sis)
%
% All arrays are flat array_dv: A is a 4 x n rank-2 dv of reals, AJ a 4 x n
% rank-2 dv of integer column indices, x0/g rank-1 dv vectors.  main returns
% BOTH the iteration count and the final vector so the computation is
% value-checkable end to end.

define main

type OneDim  = array_dv[real];
type TwoDim  = array_dv[real];      % flat rank-2, element (i,j) via A[i,j]
type TwoDimI = array_dv[integer];   % flat rank-2 integer indices


function r_sqrt(x : real returns real)
  real( sqrt(double_real(x)) )
end function


function dist(n : integer; x, y : OneDim returns real)
  r_sqrt(for i in 1, n
           x_y := (x[i] - y[i]) * (x[i] - y[i])
         returns value of sum x_y
         end for)
end function


function spmul(n  : integer; A    : TwoDim;
               AJ : TwoDimI; x, g : OneDim
               returns OneDim)
  for i in 1, n
    ax := A[1,i] * x[AJ[1,i]] + A[2,i] * x[AJ[2,i]] +
          A[3,i] * x[AJ[3,i]] + A[4,i] * x[AJ[4,i]]
  returns array_dv of g[i] + ax
  end for
end function


function main(n  : integer; A     : TwoDim;
              AJ : TwoDimI; x0, g : OneDim
              returns integer, OneDim)
  for initial
    ncount := 0;
    x      := x0
  repeat
    ncount  := old ncount + 1;
    x       := spmul(n, A, AJ, old x, g);
    x_error := dist(n, old x, x)
  until ncount = 10 | x_error < 0.0
  returns value of ncount
          value of x
  end for
end function
