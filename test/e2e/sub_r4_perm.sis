% rank-4: a[i,j,k,l] = b[j,i,k,l] + c[k,l,j,i].
% b[..]=i*1000+j*100+k*10+l ; c[..]=i+j+k+l ; N=2
% a[1,2,1,2] = b[2,1,1,2] + c[1,2,2,1] = 2112 + 6 = 2118
define main
function main(N: integer returns integer)
  let
    b := for i in 1,N cross j in 1,N cross k in 1,N cross l in 1,N
         returns array_dv of i*1000 + j*100 + k*10 + l end for;
    c := for i in 1,N cross j in 1,N cross k in 1,N cross l in 1,N
         returns array_dv of i + j + k + l end for;
    a := for i in 1,N cross j in 1,N cross k in 1,N cross l in 1,N
         returns array_dv of b[j,i,k,l] + c[k,l,j,i] end for
  in a[1,2,1,2] end let
end function
