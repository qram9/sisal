% GAUSS-JORDAN — DV variant, explicit-rank conventions
%
%   A[i,j]                 LOAD a scalar  (index count == array rank)
%   A[i]                   LOAD a scalar from a 1-D array
%   DV_RANK_REDUCE(A, i)   READ a ROW     (drop the leading axis: rank-2 -> rank-1)
%   DV_RANK_REDUCE(A,(i,j))READ a fiber from a 3-D array (drop two axes)
%   A[i: v]                REPLACE — v's rank decides: scalar v -> element, row v -> row

define Main


% idfamax / idfmax take a 1-D row; A[i] is a scalar load.
function idfamax( A: array_dv[double]; n: integer returns integer )
  for i in 1, n
  returns value of argmax abs(A[i])
  end for
end function

function idfmax( A: array_dv[double]; n: integer returns integer )
  for i in 1, n
  returns value of argmax A[i]
  end for
end function


function GetPivot( n: integer; A: array_dv[double]; PIVR: array_dv[integer]
                   returns integer, integer )
  let
    cols, maxs :=
      for i in 1, n
        col, max := if PIVR[i] = 0 then
                      let imax := idfamax( DV_RANK_REDUCE(A, i), n ) in   % row i (rank-reduce)
                        imax, abs(A[i, imax])                            % element load
                      end let
                    else
                      0, -1.0d0
                    end if
      returns array_dv of col
              array_dv of max
      end for;

    irow := idfmax( maxs, n )
  in
    cols[irow], irow
  end let
end function


function Compute( n, pvtrow: integer; Ain: array_dv[double]; Bin: array_dv[double]
                  returns array_dv[double], array_dv[double] )
  for i in 1, n
    pvtele     := Ain[pvtrow, pvtrow];
    Arow, Bele := if i = pvtrow then
                    for j in 1, n
                    returns array_dv of Ain[i, j] / pvtele
                    end for,
                    Bin[i] / pvtele
                  else
                    let multipler := Ain[i, pvtrow] / pvtele in
                      for j in 1, n
                      returns array_dv of Ain[i, j] - multipler * Ain[pvtrow, j]
                      end for,
                      Bin[i] - multipler * Bin[pvtrow]
                    end let
                  end if
  returns array_dv of Arow
          array_dv of Bele
  end for
end function


function Main( n: integer; Ain: array_dv[double]; Bin: array_dv[double]
               returns array_dv[double] )
  for initial
    I    := 0;
    A, B := Ain, Bin;
    PIVR := for j in 1, n returns array_dv of 0 end for
  while I < n repeat
    I    := old I + 1;
    Icol, Irow := GetPivot( n, old A, old PIVR );

    A1, B1 := if Icol ~= Irow then
                % A 2-D: '..' makes the target a ROW (rank-1 slab) -> DV_RANK_REPLACE
                old A[Icol, .. : DV_RANK_REDUCE(old A, Irow);
                      Irow, .. : DV_RANK_REDUCE(old A, Icol)],
                % B 1-D: values are SCALARS -> element replace
                old B[Icol: old B[Irow];
                      Irow: old B[Icol]]
              else
                old A, old B
              end if;

    PIVR := old PIVR[Icol: 1];
    A, B := Compute( n, Icol, A1, B1 )
  returns value of B
  end for
end function
