% 8-QUEENS — DV variant
%
% Rewrite of 8queens.sis using array_dv.
%
% DV changes:
%   • queen_vec = array_dv[integer]: a pre-allocated N-slot vector of queen
%     column positions, updated functionally with element replacement.
%   • sol_list is a FLAT rank-2 array_dv (solutions × n), not an array of
%     arrays: every solution is a fixed-length row, so the solution list is
%     rectangular by construction.  Per the dv convention the TYPE stays
%     array_dv[integer] — rank is a runtime property of the dope; a single
%     complete solution is a 1×n slab and catenate stacks slabs along axis 0
%     (rank-poly addh).
%   • The per-column candidate loop generates all n row assignments densely,
%     builds a boolean mask in parallel, then COMPRESS keeps the valid ROWS
%     of the rank-2 candidate block — data-parallel filtering (stream
%     compaction) instead of conditionals.  Rows are read back with the
%     rank-reducing slice valid_ext[i, ..].
%
% queen_vec[col] = row of the queen placed in column col (1-based indices).
% Slots for not-yet-placed columns hold the sentinel value 0.

define Main

type queen_vec   = array_dv[integer];
type sol_list    = array_dv[integer];   % flat rank-2 at runtime: solutions x n

% Return true if placing a queen at (r, c) conflicts with any queen
% already placed in columns 1 .. c-1.
function in_check(r, c : integer; queens : queen_vec returns boolean)
  for col in 1, c-1
    row_col := queens[col]
  returns value of sum
    (r = row_col) |
    ((row_col + col) = (r + c)) |
    ((row_col - col) = (r - c))
  end for
end function

% Recursively place queens in columns col .. n.
% queens: partial assignment (cols 1..col-1 filled, rest zero).
% Returns all complete solutions as a rank-2 slab (k x n).
function Place(n, col : integer; queens : queen_vec returns sol_list)
  if col > n then
    for i in 1, 1                      % one complete solution: a 1 x n slab
    returns array_dv of queens
    end for
  else
    let
      % Build all n candidate extensions (rank-2, n x n) and a validity
      % mask (rank-1 bool) in parallel.
      all_ext, ok :=
        for row in 1, n
        returns array_dv of queens[col : row]
                array_dv of ~in_check(row, col, queens)
        end for;
      valid_ext := COMPRESS(ok, all_ext);
      nvalid    := for f in ok
                   returns value of sum (if f then 1 else 0 end if)
                   end for
    in
      % Recurse into each surviving candidate row and stack all results.
      for i in 1, nvalid
        subs := Place(n, col + 1, valid_ext[i, ..])
      returns
        value of catenate subs
      end for
    end let
  end if
end function

% Main entry point.  Call with level = 8 for the standard problem.
% The initial queen_vec is all-zeros (no queens placed yet).
function Main(level : integer returns sol_list)
  let
    empty := for j in 1, level returns array_dv of 0 end for
  in
    Place(level, 1, empty)
  end let
end function
