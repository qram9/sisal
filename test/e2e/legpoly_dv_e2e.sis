% Legendre Polynomials of 1st Kind — DV variant (based on LegPoly.sis)
%
% DV changes:
%   • ArrDreal1 = array_dv[double_real]: the polynomial coefficient array is DV.
%   • singleton(v) helper replaces ARRAY ArrDreal1 [1: v].
%   • RETURNS ARRAY of 0.0d0 → RETURNS ARRAY_DV of 0.0d0 in the fill forall.
%   • All indexed element-update operations on pLoop1/ppp/p4 work unchanged
%     on DV arrays.

DEFINE LegendrePolyOf1stKind

type ArrDreal1 = array_dv[double_real]

global SIN(num : double_real RETURNS double_real)
global COS(num : double_real RETURNS double_real)
global SQRT(num : double_real RETURNS double_real)


function singleton( v: double_real returns ArrDreal1 )
  for dummy in 1, 1 returns array_dv of v end for
end function


FUNCTION LegendrePolyOf1stKind(ir, irmax2, jxxmx : integer;
                coas, sias, deltas : real
                RETURNS ArrDreal1)
LET
p := LET
    coa   := double_real(coas);
    sia   := double_real(sias);
    delta := double_real(deltas);
    irpp  := ir + 2;
    theta := delta;
    sqr2  := SQRT(2.0d0);
    pp :=  FOR INITIAL
            n      := 1;
            c1     := sqr2;
            pLoop1 := singleton(1.0d0 / sqr2) ||
                      FOR jm IN 2, jxxmx
                      RETURNS ARRAY_DV of 0.0d0
                      END FOR;

           WHILE n <= irpp REPEAT
            n   := old n + 1;
            fn  := double_real(old n);
            fn2 := 2.0d0 * fn;
            fn2sq := fn2 * fn2;
            c1 := old c1 * SQRT(1.0d0 - 1.0d0 / fn2sq);
            c3 := c1 / SQRT(fn * (fn + 1.0d0));

            s1, s2 :=
              FOR INITIAL
               kk := 1;
               ang := fn * theta;
               n1 := old n + 1;
               ss1, ss2 := 0.0d0, 0.0d0;
               c4, c5 := 1.0d0, fn;
               a, b := -1.0d0, 0.0d0;

              WHILE kk <= n1 REPEAT
               kk := old kk + 2;
               k  := old kk - 1;
               ss2 := old ss2 + old c5 * SIN(old ang) * old c4;
               c4t := if k = old n then 0.5d0 * old c4
                      else old c4
                      end if;
               ss1 := old ss1 + c4t * COS(old ang);
               a   := old a + 2.0d0;
               b   := old b + 1.0d0;
               fk  := double_real(k);
               ang := theta * (fn - fk - 2.0d0);
               c4  := (a * (fn - b + 1.0d0) / (b * (fn2 - a))) * c4t;
               c5  := old c5 - 2.0d0
              RETURNS VALUE of ss1
                      VALUE of ss2
              END FOR;

            pLoop1 := IF old n - irpp < 0
                      THEN old pLoop1[old n + 1 : s1 * c1; old n + irmax2 : s2 * c3]
                      ELSEIF old n - irpp = 0
                      THEN old pLoop1[old n + irmax2 : s2 * c3]
                      ELSE old pLoop1
                      END IF

           RETURNS VALUE of pLoop1
           END FOR;

    p2 :=
      IF ir = 2
      THEN pp
      ELSE FOR INITIAL
            m   := 2;
            ppp := pp
           WHILE m <= ir REPEAT
            m    := old m + 1;
            fm   := double_real(old m);
            fm1, fm2, fm3 := fm - 1.0d0, fm - 2.0d0, fm - 3.0d0;
            mm1  := old m - 1;
            m1   := old m + 1;
            c6   := SQRT((2.0d0 * fm + 1.0d0) / (2.0d0 * fm));
            p5   := old ppp[irmax2 * old m + 1 :
                            c6 * sia * old ppp[irmax2 * mm1 + 1]];
            mpir := old m + ir + 1;
            mt   := old m;

            ppp := FOR INITIAL
                    l  := m1;
                    p4 := p5;
                   WHILE l <= mpir REPEAT
                    l  := old l + 1;
                    fn := double_real(old l);
                    c7 := (fn * 2.0d0 + 1.0d0) / (fn * 2.0d0 - 1.0d0);
                    c8 := (fm1 + fn) / ((fm + fn) * (fm2 + fn));
                    c  := SQRT((fn * 2.0d0 + 1.0d0) /
                               (fn * 2.0d0 - 3.0d0) * c8 * (fm3 + fn));
                    d  := SQRT(c7 * c8 * (fn - fm1));
                    e  := SQRT(c7 * (fn - fm) / (fn + fm));
                    lm     := irmax2 * mt + old l - mt + 1;
                    lmm2   := irmax2 * (mt - 2) + old l - mt + 3;
                    lm1mm2 := lmm2 - 1;
                    lm2mm2 := lm1mm2 - 1;
                    lm1m   := lm - 1;

                    p4 := IF old l - mpir < 0
                          THEN old p4[lm : c * old p4[lm2mm2]
                                         - d * old p4[lm1mm2] * coa
                                         + e * old p4[lm1m]   * coa]
                          ELSEIF old l - mpir > 0
                          THEN old p4
                          ELSE LET
                                a := SQRT((fn * fn - 0.25d0) /
                                          (fn * fn - fm * fm));
                                b := SQRT((2.0d0 * fn + 1.0d0) *
                                          (fn - fm - 1.0d0) * (fn + fm1)
                                       / ((2.0d0 * fn - 3.0d0) * (fn - fm)
                                            * (fn + fm)));
                                lm2m := lm1m - 1;
                               IN
                                old p4[lm : 2.0d0 * a * coa * old p4[lm1m]
                                             - b * old p4[lm2m]]
                               END LET
                          END IF
                   RETURNS VALUE of p4
                   END FOR;
           RETURNS VALUE of ppp
           END FOR
      END IF
    IN p2
    END LET;
IN p
END LET

END FUNCTION
