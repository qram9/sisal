define main
% Matrix multiplication - DV variant
% realmatrix is a flat rank-2 array_dv; built by a cross forall (was
% nested array_fill of an array-of-arrays).

type realmatrix = array_dv[real];

function innerproduct_(rowsize:integer; a,b:realmatrix; row,column:integer
			returns real)
    for i in 1, rowsize
    returns value of sum a[row,i]*b[i,column]
    end for
end function

function main(rowsize:integer returns real)
let
    rma := for i in 1, rowsize cross j in 1, rowsize
           returns array_dv of 1.1
           end for ;
    rmb := rma ;
    rmc :=
    for i in 1, rowsize cross j in 1, rowsize
    returns array_dv of innerproduct_(rowsize, rma, rmb, i, j)
    end for
in
    rmc[1, 1]
end let
end function
