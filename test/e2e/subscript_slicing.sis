% subscript_slicing.sis — tests row slicing, column slicing, and scalar load on multi-rank array_dv
define main

type OneD = array_dv[double];
type TwoD = array_dv[double];

function main( returns OneD, OneD, double )
  let
    A := for r in 1, 3
           row := for c in 1, 3
                    val := double_real(r - 1) * 3.0 + double_real(c);
                  returns array_dv of val
                  end for;
         returns array_dv of row
         end for;

    row1  := A[1, ..];
    col2  := A[.., 2];
    val32 := A[3, 2];
  in
    row1,
    col2,
    val32
  end let
end function
