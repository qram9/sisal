define Main

type AR = array_dv[integer];
type UN = union[A : integer; B : real; D : AR];

function TestUnion(X : UN; returns real, real)
  tagcase P := X
    tag B     : P, P
    tag D     : 3.0, 5.0
    otherwise : 4.0, 2.0
  end tagcase
end function

function Main(sel : integer; val : real; returns real, real)
  let
    u_a := union UN [ A: 42 ];
    u_b := union UN [ B: val ];
    u_d := union UN [ D: array_fill(1, 3, 10) ]
  in
    if sel = 1 then
      TestUnion(u_a)
    else 
      if sel = 2 then
        TestUnion(u_b)
      else
        TestUnion(u_d)
      end if
    end if
  end let
end function
