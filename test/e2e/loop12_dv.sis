% First Difference

Define  Main

%type double = double_real;
type OneD   = array_dv[double];

function Loop12( n:integer; Y:OneD returns OneD )
  for i in 1,n returns
  array_dv of Y[i+1] - Y[i]
  end for
end function

function Main( rep,n:integer; Yin:OneD returns OneD )
   for i in 1, rep
       Y := Loop12( n, Yin );
   returns value of Y
   end for
end function
