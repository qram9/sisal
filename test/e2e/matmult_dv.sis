%$entry=multiply
define multiply

type TwoD = array_dv[double_real];   % flat rank-2 dv, element (i,j) via A[i,j]

% Multiply A[1..x, 1..y] and B[1..y, 1..z] (all flat rank-2 array_dv).
function multiply(x,y,z: integer; A, B: TwoD returns TwoD)

  for i in 1, x cross j in 1, z
    Cij := for k in 1, y
           returns value of sum A[i, k] * B[k, j]
           end for
  returns array_dv of Cij
  end for

end function % multiply
