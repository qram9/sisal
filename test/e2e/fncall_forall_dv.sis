% multi-output function called inside a forall, both outputs used
define main
type IOneD = array_dv[integer];
function pair( n: integer returns integer, integer ) n*2, n*3 end function
function main( returns IOneD )
  for i in 1, 3
    a, b := pair(i);
    x := a + b;
  returns array_dv of x
  end for
end function