define mat_ops,
  mat2_times_mat2,
  mat2_times_vec2,
  vec2_times_mat2,
  mat3_times_mat3,
  mat3_times_vec3,
  vec3_times_mat3,
  mat4_times_mat4,
  mat4_times_vec4,
  vec4_times_mat4

% --- MAT2 ---

% mat2 * mat2 → mat2
function mat2_times_mat2( a : mat2; b : mat2 returns mat2 )
  a * b
end function

% mat2 * float2 → float2  (column vector transform)
function mat2_times_vec2( m : mat2; v : float2 returns float2 )
  m * v
end function

% float2 * mat2 → float2  (row vector transform)
function vec2_times_mat2( v : float2; m : mat2 returns float2 )
  v * m
end function

% --- MAT3 ---

function mat3_times_mat3( a : mat3; b : mat3 returns mat3 )
  a * b
end function

function mat3_times_vec3( m : mat3; v : float3 returns float3 )
  m * v
end function

function vec3_times_mat3( v : float3; m : mat3 returns float3 )
  v * m
end function

% --- MAT4 ---

function mat4_times_mat4( a : mat4; b : mat4 returns mat4 )
  a * b
end function

function mat4_times_vec4( m : mat4; v : float4 returns float4 )
  m * v
end function

function vec4_times_mat4( v : float4; m : mat4 returns float4 )
  v * m
end function
