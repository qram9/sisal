define Main
  
% Main is a very, very slowly converging approximation to pi
%    It uses the alternating series 1 - 1/3 + 1/5 - 1/7 ...
%    This version is parallelized.
  
function Main ( Cycles:integer returns real )

  let a, b :=
    for i in 1, Cycles/2
    returns value of sum 1.0/real(4*i-3)
            value of sum 1.0/real(4*i-1)
    end for
  in
    (a-b)*4.0
  end let
end function
