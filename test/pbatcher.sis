define Main

type OneDim = array[ integer ];

global BITWISE_AND( a,b:integer returns integer )

function CeilingOfLog2( N: integer returns integer )
  for initial
    L := 0; TwoToTheL := 1
  while TwoToTheL < N repeat
    L := old L + 1; TwoToTheL := 2*old TwoToTheL
  returns value of L
  end for
end function

function Main( K: OneDim returns OneDim )
  let
    N := array_size(K); TTM1 := exp(2,CeilingOfLog2(N)-1);
  in
    for initial
      P := TTM1; B := array_setl(K,0);
    repeat
      P := old P/2;
      B := for initial
	     Q := TTM1; R := 0; D := old P; C := old B
	   repeat
	  C :=
	    for Elt in old C at I
	      NewElt :=
		if ( BITWISE_AND( I, old P ) = old R ) & ( I + old D < N ) then
		  min( Elt, old C[ I+old D ] )
		elseif ( BITWISE_AND( I-old D, old P ) = old R ) & ( I >= old D ) then
		  max( Elt, old C[ I-old D ] )
		else
		  Elt
		end if;
	    returns array of NewElt
	    end for;
	     D := old Q - old P; Q := old Q / 2; R := old P
	   until Q <= old P
	   returns value of C
	   end for
    until P <= 0
    returns value of B
    end for
  end let
end function % Main
