define slab
%
%  inside.sis     (c) Copyright 1986, 1987, 1988. All rights reserved
%  Version 3.     Regents of the University of California
%
% ::::::::::::::::::::::::::::::::::::::::::::::::::
%       When running this program with  'di'  type
%             di inside faces gauss
%       and run slab(n) for some integer n, the number of intervals.
%
%       In order to get the solution only on the faces, type
%             di slab faces gauss
%       and run slab(n) for some integer n, the nunmber of intervals.
%
%  This module contains the driver and the routines for 
%  computing the solution of the radiative transfer problem 
%  in the interior of a slab using the algorithm from the 
%  paper `On the Use of the FN Method with Splines for 
%  Radiative Transfer Problems' by R. C. Y. Chin, G. W. 
%  Hedstrom, and C. E. Siewert, J. Quant. Spectrosc. Radiat. 
%  Transfer 39 (1988), 205--217.
%
% The main program is `slab'. 
% ::::::::::::::::::::::::::::::::::::::::::::::::::
% 
type RealVector = array[real];
type RealMatrix = array[RealVector]
global expon(x : real returns real)
global get_nu0(c, eps : real returns real)
global form_knots(interv : integer; returns RealVector,
  RealVector)
global form_col_pts(interv : integer; knots : RealVector; 
  nu0 : real returns RealVector)
global s_int(nu, mu0, delta : real returns real)
global c_int(nu, mu0, delta, eps : real returns real)
global form_k(block_size : integer; mu0, delta : real;
  col_pts : RealVector; eps : real returns RealVector)
global form_b11(interv : integer; c : real;
  knots, lengths, col_pts : RealVector; eps : real
  returns RealMatrix)
global form_b12(interv : integer; c, delta : real;
  knots, lengths, col_pts : RealVector; eps : real
  returns RealMatrix)
global factor(n : integer; b : RealMatrix returns
  RealMatrix, RealMatrix)
global solve_down(n : integer; l : RealMatrix;
  k : RealVector returns RealVector)
global solve_up(n : integer; u : RealMatrix;
  y : RealVector returns RealVector)
global a_alpha_even(knot, length_l, length_r, col_pt, eps : 
  real returns real)
global a_alpha_odd(knot, length_l, length_r, col_pt, eps : 
  real returns real)
global phi_od_r(y : real returns real)
global phi_od_l(y : real returns real)
global phi_ev_r(y : real returns real)
global phi_ev_l(y : real returns real)
global spline(mu : real; interv : integer; knots, lengths, 
  a : RealVector returns real)
global answers(interv, jmu : integer; mu, knots, lengths, 
  coef_l, coef_r : RealVector; c : real returns 
  RealVector, RealVector)
% *********************************************
%                    form_b12_in
% *********************************************
function form_b12_in(interv : integer; c : real;
  knots, lengths, col_pts : RealVector; eps : real
  returns RealMatrix)
% this function forms the matrix  b12_in  from the
% collocation method to evaluate the solution in the
% interior.
% input data:
%   interv,  the order of  b  is actually  2*interv+2
%   c,  the relative loss due to scattering
%   knots,  the knots of the spline
%   lengths,  the lengths of the intervals
%   col_pts,  the collocation points
%   eps,  the tolerance
% output data:
%   b12_in,  the matrix
% --------------------------------------------------
let
  block_size := 2*interv + 2
in
  for i in 1, block_size
    row :=
      for kn in 0, interv
      seg := array[1 : -c*a_alpha_even(knots[kn], 
        lengths[kn], lengths[kn+1], col_pts[i], eps),
        -c*a_alpha_odd(knots[kn], lengths[kn],
        lengths[kn+1], col_pts[i], eps) ]
      returns value of catenate seg
      end for
  returns array of row
  end for
end let
end function
% ******************************************************
%                    form_rhs
% ******************************************************
function form_rhs(block_size : integer; mu0, delta : real; 
  col_pts : RealVector; x, c, eps : real; loss : RealVector
  returns RealVector)
% this function forms the right-hand side of the matrix
% equationfor the solution in the interior at the point  x,
% 0 < x < delta.
% input data:
%   block_size,  the number of collocation points (with nu0)
%   mu0,  the incoming radiation is  0.5*(delta function)(mu - mu0)
%   delta,  the thickness of the slab
%   col_pts,  the collocation points
%   x,  the point of evaluation
%   c,  the relative loss due to scattering
%   eps,  the tolerance
%   loss,  the effect of radiation at the ends
% output data:
%   rhs,  the right-hand side
% -------------------------------------------------------
% ------------------ first block --------------------------
for i in 1, block_size
  exponen :=
    if (col_pts[i] = 0.0) then 0.0
    else expon(-(delta-x)/col_pts[i])
    end if;
  rhs := exponen*loss[i] + 2.0*s_int(col_pts[i], mu0, 
    delta-x)*expon(-x/mu0)
returns array of rhs
end for ||
% ------------------ last block_size -----------------------
for i in 1, block_size
  exponen := 
    if (col_pts[i] = 0.0) then 0.0
      else expon(-x/col_pts[i])
    end if;
  rhs := exponen*loss[block_size+i] + 
    2.0*c_int(col_pts[i], mu0, x, eps)
returns array of rhs
end for
end function
% ****************************************************
%                      inner_ans
% ****************************************************
function inner_ans(interv : integer; x : real;
  jmu : integer; mu : RealVector; mu0, c, delta, eps : real;
  knots, lengths, col_pts, loss : RealVector;
  l, u : RealMatrix returns RealVector)
% ----------------------------------------------------
% for a given value of  x  this function gets the right-hand 
%  side for the matrix problem for the radiation field at an 
%  interior point  x,  and it solves this problem.
%
% input data:
%   interv,  the number of intervals in the spline,
%   x,  the interior point at which to evaluate the solution,
%   jmu,  the number of printout points,
%   mu,  the direction cosines at which to evaluate the solution,
%   mu0,  the direction cosine of incoming radiation,
%   c,  the relative loss due to scattering,
%   delta,  the thickness of the slab,
%   eps,  the tolerance,
%   knots,  the knots of the spline,
%   lengths,  the lengths of the intervals of the spline,
%   col_pts,  the collocation points,
%   loss,  the effect of the flux out of the faces of the slab,
%   l, u,  the factors of the matrix by gaussina elimination,
% output data:
%   field,  the angular fluxes at  x,  -1 <= mu <= 1
% ----------------------------------------------------------
if ((x <= 0.0) | (x >= delta)) then
  for j in 1, 2*(2*interv + 2)
    field_j := error[real]
  returns array of field_j
  end for
else
let
  block_size := 2*interv + 2;
  rhs := form_rhs(block_size, mu0, delta, col_pts, 
        x, c, eps, loss);
  y := solve_down(2*block_size, l, rhs);
  soln := solve_up(2*block_size, u, y);
  coef_l, coef_r := for j in 1, block_size
      xlj := soln[j];
      xrj := soln[block_size+j]
    returns
      array of xlj
      array of xrj
    end for;  %  the coefficents of the splines
  psi_l, psi_r := 
    for j in 0, jmu
      spline_lj := 0.5*c*spline(mu[j], interv, knots, 
        lengths, coef_l);  %  backward
      spline_rj := 0.5*c*spline(mu[j], interv, knots, 
        lengths, coef_r)  %  forward
    returns
      array of spline_lj
      array of spline_rj
    end for;
  reverse := 
    for j in 0, jmu
      reverse_j := psi_l[jmu - j]
    returns array of reverse_j
    end for
in
  reverse  ||  psi_r
end let
end if
end function
% ****************************************************
%                 interior
% ****************************************************
function interior(interv, jmu : integer; mu : RealVector;
  nx : integer; x : RealVector; mu0, c, delta : real;  
  knots, lengths, col_pts :  RealVector; b11 : RealMatrix; 
  coef_l, coef_r : RealVector; eps : real
  returns RealMatrix)
% this function computes the solution at the interior
% points of a slab and prints out the answers.
% input data:
%   interv,  the number of intervals in  mu
%   jmu,  the number of angular points in output
%   mu,  the angular points for output,
%   nx,  the number of interior points
%   x,  the interior points
%   mu0,  the direction of incoming radiation
%   c,  the relative loss due to scattering
%   delta,  the thickness of the slab
%   knots,  the knots
%   lengths,  the lengths of the intervals
%   col_pts,  the collocation points (with nu0)
%   b11,  the upper left block for the surface problem
%   coef_l,  the solution of the surface problem, left face
%   coef_r,  the solution of the surface problem, right face
%   eps,  the tolerance
% output data:
%   \psi_r, the forward radiation field
%   \psi_l, the backward radiation field
% -------------- form the matrix ---------------------
let
  block_size := 2*interv + 2;
  b12_in := form_b12_in(interv, c, knots, lengths, col_pts, 
    eps);
  b_in := 
    for j in 1, block_size
      row := b11[j] || b12_in[j]
    returns array of row
    end for  ||
    for j in 1, block_size
      row := b12_in[j] || b11[j]
    returns array of row
    end for;  %  the whole matrix
  l, u := factor(2*block_size, b_in);
% ---------------- form the right-hand sides and solve ----
  loss :=
    for i in 1, block_size
      loss_i :=
        for j in 1, block_size
          loss_ij := b12_in[i, j]*coef_r[j]
        returns value of sum loss_ij
        end for
    returns array of loss_i
    end for  ||
    for i in 1, block_size
      loss_i :=
        for j in 1, block_size
          loss_ij := b12_in[i, j]*coef_l[j]
        returns value of sum loss_ij
        end for
    returns array of loss_i
    end for;
  field :=
    for j in 1, nx
      field_j := inner_ans(interv, x[j], jmu, mu, mu0, 
        c, delta, eps, knots, lengths, col_pts, loss, l, u)
    returns array of field_j
    end for
in
  field
end let
end function
% ******************************************************
%                      slab
% ******************************************************
function slab(interv : integer returns RealVector, 
  RealVector, RealVector, RealMatrix)
% input data
%   interv,  the number of intervals
% output data:
%   mu,  the sampling angles
%   \psi_l,  the exit angular fluxes on the left face
%   \psi_r,  the exit angular fluxes on the right face
%   x,  the interior points at which to evaluate the solution,
%   field,  the angular fluxes at the points  x
% -------------------- set up everything -------------
let 
% ----------------- initial data --------------------
  c := 0.9;  %  the relative loss due to scattering (0 < c < 1)
  mu0 := 1.0;  %  the direction cosine for incoming radiation
  jmu := 10;   %  the number of evaluation points for answers
  dmu := 1.0/real(jmu);
  mu := 
    for j in 0, jmu
      muj := real(j)*dmu
    returns array of muj
    end for;   %  the evaluation points for answers
  delta := 1.0;  %  the thickness of the slab
  eps := 1.0e-10;  %  the tolerance
  nx := 5;  %  the number of interior points
  x := array[1 : 0.05, 0.1, 0.2, 0.5, 0.75];  %  vector of interior points
% ------------------- derived data ------------------
  nu0 := get_nu0(c, eps);  %  the eigenvalue
  knots, lengths := form_knots(interv);  %  the knots for the splines
  col_pts := form_col_pts(interv, knots, nu0);  %  the collocation points
  block_size := 2*(interv + 1);  %  the matrix has 4 blocks, each of this size
  k := form_k(block_size, mu0, delta, col_pts, eps);  %  the right-hand side
  b11 := form_b11(interv, c, knots, lengths, col_pts, eps);
   % first block of matrix
  b12 := form_b12(interv, c, delta, knots, lengths,col_pts, eps); %  2nd block
  b := 
    for j in 1, block_size
      row := b11[j] || b12[j]
    returns array of row
    end for  ||
    for j in 1, block_size
      row := b12[j] || b11[j]
    returns array of row
    end for;  %  the whole matrix
% --------------------- solve ------------------------
  l, u := factor(2*block_size, b);
  yk := solve_down(2*block_size, l, k);
  xk := solve_up(2*block_size, u, yk);
  coef_l, coef_r := for j in 1, block_size
      xlj := xk[j];
      xrj := xk[block_size+j]
    returns
      array of xlj
      array of xrj
    end for;  %  the coefficents of the splines
  psi_l, psi_r := answers(interv, jmu, mu, knots, lengths,
    coef_l, coef_r, c);  %  the values of the splines on the faces
  field := interior(interv, jmu, mu, nx, x, mu0, c, delta, 
    knots, lengths, col_pts, b11, coef_l, coef_r, eps)  % interior 
in
  psi_l, psi_r, x, field
end let
end function

