% rank-5 full reverse: a[i,j,k,l,m] = b[m,l,k,j,i].
% b[..]=i*10000+j*1000+k*100+l*10+m ; N=3
% a[1,2,3,1,2] = b[2,1,3,2,1] = 21321
define main
function main(N: integer returns integer)
  let
    b := for i in 1,N cross j in 1,N cross k in 1,N cross l in 1,N cross m in 1,N
         returns array_dv of i*10000 + j*1000 + k*100 + l*10 + m end for;
    a := for i in 1,N cross j in 1,N cross k in 1,N cross l in 1,N cross m in 1,N
         returns array_dv of b[m,l,k,j,i] end for
  in a[1,2,3,1,2] end let
end function
