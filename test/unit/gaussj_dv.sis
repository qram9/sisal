% GAUSS-JORDAN — DV variant
%
% A[i]                   — rank reduce: returns sub-array with rank-1 less
% DV_ELEMENT(A, i)       — explicit scalar load, 1-based
% DV_ELEMENT(A, i, j)    — explicit 2-D scalar load (lowers as rank-reduce then DV_ELEMENT)

define Main


function idfamax( A: array_dv[double]; n: integer returns integer )
  for i in 1, n
  returns value of argmax abs(DV_ELEMENT(A, i))
  end for
end function

function idfmax( A: array_dv[double]; n: integer returns integer )
  for i in 1, n
  returns value of argmax DV_ELEMENT(A, i)
  end for
end function


function GetPivot( n: integer; A: array_dv[double]; PIVR: array_dv[integer]
                   returns integer, integer )
  let
    cols, maxs :=
      for i in 1, n
        col, max := if DV_ELEMENT(PIVR, i) = 0 then
                      let imax := idfamax( A[i], n ) in
                        imax, abs(DV_ELEMENT(A, i, imax))
                      end let
                    else
                      0, -1.0d0
                    end if
      returns array_dv of col
              array_dv of max
      end for;

    irow := idfmax( maxs, n )
  in
    DV_ELEMENT(cols, irow), irow
  end let
end function


function Compute( n, pvtrow: integer; Ain: array_dv[double]; Bin: array_dv[double]
                  returns array_dv[double], array_dv[double] )
  for i in 1, n
    pvtele     := DV_ELEMENT(Ain, pvtrow, pvtrow);
    Arow, Bele := if i = pvtrow then
                    for j in 1, n
                    returns array_dv of DV_ELEMENT(Ain, i, j) / pvtele
                    end for,
                    DV_ELEMENT(Bin, i) / pvtele
                  else
                    let multipler := DV_ELEMENT(Ain, i, pvtrow) / pvtele in
                      for j in 1, n
                      returns array_dv of DV_ELEMENT(Ain, i, j) - multipler * DV_ELEMENT(Ain, pvtrow, j)
                      end for,
                      DV_ELEMENT(Bin, i) - multipler * DV_ELEMENT(Bin, pvtrow)
                    end let
                  end if
  returns array_dv of Arow
          array_dv of Bele
  end for
end function


function Main( n: integer; Ain: array_dv[double]; Bin: array_dv[double]
               returns array_dv[double] )
  for initial
    I    := 0;
    A, B := Ain, Bin;
    PIVR := for j in 1, n returns array_dv of 0 end for
  while I < n repeat
    I    := old I + 1;
    Icol, Irow := GetPivot( n, old A, old PIVR );

    A1, B1 := if Icol ~= Irow then
                old A[Icol: old A[Irow]; Irow: old A[Icol]],
                old B[Icol: DV_ELEMENT(old B, Irow);
                      Irow: DV_ELEMENT(old B, Icol)]
              else
                old A, old B
              end if;

    PIVR := old PIVR[Icol: 1];
    A, B := Compute( n, Icol, A1, B1 )
  returns value of B
  end for
end function
