% Index of First Absolute Min
function aminD( N:integer; X:OneD returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( abs(X[old K]) < abs(X[old Idx]) ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
end function
function aminR( N:integer; X:OneR returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( abs(X[old K]) < abs(X[old Idx]) ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
