
define main

type OneD = array[double_real];
type OneR = array[real];
type OneI = array[integer];


% Index of First Max
function maxD( N:integer; X:OneD returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( X[old K] > X[old Idx] ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
end function
function maxR( N:integer; X:OneR returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( X[old K] > X[old Idx] ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
end function
function maxI( N:integer; X:OneI returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( X[old K] > X[old Idx] ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
end function

% Index of First Absolute Max
function amaxD( N:integer; X:OneD returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( abs(X[old K]) > abs(X[old Idx]) ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
end function
function amaxR( N:integer; X:OneR returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( abs(X[old K]) > abs(X[old Idx]) ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
end function
function amaxI( N:integer; X:OneI returns integer )
  for initial
    Idx := 1; K := 2;
  while ( K <= N ) repeat
    Idx := if ( abs(X[old K]) > abs(X[old Idx]) ) then 
             old K  
           else 
             old Idx 
           end if;
    K := old K + 1;
  returns value of Idx
  end for
end function

