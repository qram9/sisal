% DISCRETE FOURIER TRANSFORM - FORWARD
%
% Y[K] := SUMMATION(J=1,N) X[J] * etothe( X ) For K = 1,2,...N
%         X := (2 * Pi * i (J-1) * (K-1)) / N
%
% e ** ix  := cos(x) + i*sin(x)
%

define Main

type Complex = record[ R : double_real; I : double_real ];
type OneDim  = array [Complex];

global sin( N : double_real returns double_real )
global cos( N : double_real returns double_real )

function dft( N : integer; X : OneDim returns OneDim )
    let
	Pi    := 3.1415926535897932D0;
	Theta := (2.0D0 * Pi) / double_real(N);
    in
	for K in 1, N
	    Rdata, 
	    Idata  := for J in 1, N
	                  EArg   := Theta * double_real(J-1) * double_real(K-1);
			  Er     := cos( Earg );
			  Ei     := sin( Earg );
			  Rvalue := (X[J].R * Er) - (X[J].I * Ei);
			  Ivalue := (X[J].I * Er) + (X[J].R * Ei);
		      returns value of sum Rvalue
			      value of sum Ivalue
		      end for;
	    
	returns array of record Complex [ R : Rdata; I : Idata ]
	end for
    end let
end function

function Main( N : integer returns OneDim )
    let
	Pi  := 3.1415926535897932D0;
	DRN := double_real(N);
	X   := for J in 1, N
		   Rvalue := sin( (DRN * Pi) / 8.0D0 );
		   Ivalue := 0.0D0;
               returns array of record Complex [ R : Rvalue; I : Ivalue ]
	       end for;
    in
	dft( N, X )
    end let
end function
