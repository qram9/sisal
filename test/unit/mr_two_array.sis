define Main
function Two( n: integer; A: array_dv[double]
             returns array_dv[double], array_dv[double] )
  for i in 1, n
  returns array_dv of A[i] + 1.0d0
          array_dv of A[i] * 2.0d0
  end for
end function

function Main( n: integer; A: array_dv[double] returns array_dv[double] )
  let P, Q := Two( n, A )
  in P
  end let
end function
