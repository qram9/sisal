function Add1 ( X : integer returns integer ) X + 1 end function
function Add2 ( X : integer returns integer ) X + 2 end function
function Add3 ( X : integer returns integer ) X + 3 end function

function Main ( N : integer returns integer, integer, integer )
  let #(f, g, h) := #(Add1, Add2, Add3)
  in
    f(N), g(N), h(N)
  end let
end function
