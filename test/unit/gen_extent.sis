% gen_extent.sis — generator EXPRESSION-bound lowering (forall-extent-rework).
% Each forall generator is lowered as a full graph (edge topo-walk): its bound
% math (e.g. `n-1`, `m-1`) is declared in the forall scaffold BEFORE the result
% alloc, and the RANGEGEN axis becomes the C `for` with lb/ub threaded from those
% declared bound values.  Regression for the case where a SUBTRACT in the
% generator was never lowered -> alloc/`for` referenced an undeclared C variable.

define gen_extent

% single-level expression upper bound: i runs 1..(n-1).
% n=5 -> i in 1..4 -> [1,4,9,16].
function genext_sub(n: integer returns array[integer])
  for i in 1, n-1
  returns array of i * i
  end for
end function

% expression LOWER bound too: i runs (n-3)..n.
% n=6 -> i in 3..6 -> [3,4,5,6].
function genext_lb(n: integer returns array[integer])
  for i in n-3, n
  returns array of i
  end for
end function

% cross nest with an expression bound on the INNER axis: i in 1..n, j in 1..(m-1).
% The inner `m-1` is loop-invariant, hoisted to the scaffold ahead of the rank-2
% alloc.  n=2,m=4 -> j in 1..3 -> rank2 [2,3]: 11 12 13 21 22 23.
function genext_cross(n: integer; m: integer returns array[array[integer]])
  for i in 1, n cross j in 1, m-1
  returns array of i * 10 + j
  end for
end function
