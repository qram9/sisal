% Minimal DOUBLE-nested `for initial` reproducer for the MERGE int<->array
% mis-wiring. The inner loop has MIXED carries (k,i int; Xt array) AND captures
% values from the outer scope (p, old A) -- which is what shifts the inner INIT's
% output ports and permutes its MERGE seeds. The innermost loop alone compiles
% fine (see loop2_inner_dv.sis); only this double nest mis-wires.

Define  Main

type OneD = array_dv[double];

function Main( n: integer; X: OneD returns OneD )
  for initial
      p := 0;
      A := X;
  while ( p < n ) repeat
      p := old p + 1;
      A := for initial
              k  := p;          % captures outer p (int)
              Xt := old A;       % captures outer carry A (array)
              i  := 0;
           while ( k <= n ) repeat
              k  := old k + 1;
              i  := old i + 1;
              Xt := old Xt[i: old Xt[k] + 1.0d0];
           returns value of Xt
           end for;
  returns value of A
  end for
end function
