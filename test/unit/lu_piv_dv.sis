% LU DECOMPOSITION WITH PIVOTING — DV variant (based on lu.piv.sis)
%
% DV changes:
%   • OneI = array_dv[integer], OneD = array_dv[double]: all 1-D vectors DV.
%   • TwoD = array[OneD]: matrix is an array of DV rows.
%   • Inner foralls  returns array of scalar  →  returns array_dv of scalar.
%   • array_fill(1,n,0) → for j in 1,n returns array_dv of 0 end for.
%   • for-in element iterators (for x in row, for row in A at i) work
%     unchanged: the outer array is a regular array of DV rows; the inner
%     iteration over a DV row is supported by the element-iterator form.

define Main

%type double = double_real;
type OneI = array_dv[integer];
type OneD = array_dv[double];
type TwoD = array[OneD];


function Max( A: TwoD returns double, OneD )
  for row in A
    max := for x in row
           returns value of greatest abs(x)
           end for
  returns value of greatest max
          array_dv of max
  end for
end function


function Index_of_Max( max: double; maxs: OneD; A: TwoD
                        returns integer, integer )
  let
    row := for x in maxs at i
           returns value of least i when x = max
           end for;
    col := for x in A[row] at j
           returns value of least j when abs(x) = max
           end for
  in
    row, col
  end let
end function


function Reduce_and_Max( pivot: integer;
                          PIVR: OneI; A: TwoD; B: OneD
                          returns TwoD, OneD, double, OneD )
  for row in A at i
    mult          := A[i, pivot] / A[pivot, pivot];
    rrow, max, rB :=
      if i = pivot then
        for x in row
        returns array_dv of x / A[pivot, pivot]
                value of 0.0d0
        end for,
        B[i] / A[pivot, pivot]
      elseif PIVR[i] = 1 then
        for x in row at j
        returns array_dv of x - mult * A[pivot, j]
                value of 0.0d0
        end for,
        B[i] - mult * B[pivot]
      else
        for x in row at j
          rx := x - mult * A[pivot, j]
        returns array_dv of rx
                value of greatest abs(rx)
        end for,
        B[i] - mult * B[pivot]
      end if
  returns array of rrow
          array_dv of rB
          value of greatest max
          array_dv of max
  end for
end function


function Main( n: integer; Ain: TwoD; Bin: OneD returns OneD )
  for initial
    i    := 0;
    A, B := Ain, Bin;
    PIVR := for j in 1, n returns array_dv of 0 end for;

    max, maxs := Max( A );
    row, col  := Index_of_Max( max, maxs, A )
  while i < n repeat
    i      := old i + 1;
    A1, B1 := old A[old col: old A[old row]; old row: old A[old col]],
               old B[old col: old B[old row]; old row: old B[old col]];
    PIVR   := old PIVR[old col: 1];

    A, B, max, maxs := Reduce_and_Max( old col, PIVR, A1, B1 );
    row, col        := Index_of_Max( max, maxs, A )
  returns value of B
  end for
end function
