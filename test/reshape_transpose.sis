% reshape_transpose: build flat, reshape to (n x m), transpose, flatten.
%
% A[i,j] = double_real(i*100 + j), stored row-major.
% Uses j = k - ((k-1)/m)*m  (no mod() needed).
% B2d[1,1] = A2d[1,1] = 101.0

define reshape_transpose

type FlatD = array[double_real];

function test(n, m : integer returns double_real)
let
  % row-major flat: k in 1..n*m, i=(k-1)/m+1, j=k-((k-1)/m)*m
  flat :=
    for k in 1, n * m
      i := (k - 1) / m + 1;
      j := k - ((k - 1) / m) * m
    returns array[..] of double_real(i * 100 + j)
    end for;
  A2d := reshape(flat, n, m);
  % Transpose B is (m x n): linear index over m*n, r=(k-1)/n+1, c=k-((k-1)/n)*n
  trans_flat :=
    for k in 1, m * n
      r := (k - 1) / n + 1;
      c := k - ((k - 1) / n) * n
    returns array[..] of A2d[c, r]
    end for;
  B2d := reshape(trans_flat, m, n)
in
  B2d[1, 1]    % = A2d[1,1] = 101.0
end let
end function
