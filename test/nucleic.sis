  array[0: -0.9737d0, -0.1834d0,  0.1352d0,
  	   -0.1779d0,  0.2417d0, -0.9539d0,
   	    0.1422d0, -0.9529d0, -0.2679d0,
   	    0.4837d0,  6.2649d0,  8.0285d0
       ],

