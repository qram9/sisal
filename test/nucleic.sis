           var        := try(n, i, T12);
           stack1     := array_addh(stack, var);

           stack2, 
           solutions1 := pseudoknot_domains(k+1, tfos, nucs, stack1, solutions)
         in
           array_remh(stack2), solutions1
         end let
      else
