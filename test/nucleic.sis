function init_tfo (returns tfo1)

  array[0:

%struct struct_tfo tfo_id =
  array[0: 1.0d0, 0.0d0, 0.0d0,
	   0.0d0, 1.0d0, 0.0d0,
  	   0.0d0, 0.0d0, 1.0d0,
	   0.0d0, 0.0d0, 0.0d0
       ],

%struct struct_tfo wc_tfo =
  array[0: -1.0000d0,  0.0028d0, -0.0019d0,
   	    0.0028d0,  0.3468d0, -0.9379d0,
  	   -0.0019d0, -0.9379d0, -0.3468d0,
  	   -0.0080d0,  6.0730d0,  8.7208d0
       ],

