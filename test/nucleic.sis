define main

type double = double_real;

type OneDim = array[double];
type TwoDim = array[OneDim];

%	NUCLEIC ACID CONFORMATIONS DATA BASE

type tfo       = OneDim;
type tfo1      = array[tfo];

type nuc       = TwoDim;
type nuc1      = array[nuc];
type nuc2      = array[ array[nuc] ];

type var       = record[tfo: tfo; nuc: nuc; label: integer];
type solution  = array[var];
type solution1 = array[solution];

#define P9       p0, p1, p2, p3, p4, p5, p6, p7, p8
