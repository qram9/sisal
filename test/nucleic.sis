  array[0:  0.9886d0, -0.0961d0,  0.1156d0,
   	    0.1424d0,  0.8452d0, -0.5152d0,
  	   -0.0482d0,  0.5258d0,  0.8492d0,
  	   -3.8737d0,  0.5480d0,  3.8024d0
       ],

%struct struct_tfo helix3_tfo =
  array[0:  0.9886d0,  0.1424d0, -0.0482d0,
  	   -0.0961d0,  0.8452d0,  0.5258d0,
   	    0.1156d0, -0.5152d0,  0.8492d0,
   	    3.4426d0,  2.0474d0, -3.7042d0
       ],

%struct struct_tfo g37_a38_tfo =
  array[0:  0.9991d0,  0.0164d0, -0.0387d0,
  	   -0.0375d0,  0.7616d0, -0.6470d0,
   	    0.0189d0,  0.6478d0,  0.7615d0,
  	   -3.3018d0,  0.9975d0,  2.5585d0
       ],
  
%struct struct_tfo a38_g37_tfo =
