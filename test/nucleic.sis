function P_O3a    (T12  : double;
                   n    : nuc;      i, k     : integer;
                   tfos : tfo1;     nucs     : nuc2;
                   stack: solution; solutions: solution1
           returns solution, solution1)

  if pseudoknot_constraint(n, i, stack, T12) then
     let
         var        := try(n, i, T12);
         stack1     := array_addh(stack, var);

         stack2,
         solutions1 := pseudoknot_domains(k+1, tfos, nucs, stack1, solutions)
      in
         array_remh(stack2), solutions1
      end let
  else
     stack, solutions
  end if

end function % P_O3a


function P_O3     (ns      : nuc1;
                   i, j, k : integer;
                   tfos    : tfo1;     nucs     : nuc2;
                   stack   : solution; solutions: solution1
           returns solution, solution1)

   for initial
       m   := 1;
       T12 := make_t(j, stack);

       stack1, solutions1 :=
          P_O3a(tfo_combine(ns[m, 4], T12),
                ns[m], i, k, tfos, nucs, stack, solutions);

       stack2, solutions2 :=
          P_O3a(tfo_combine(ns[m, 3], T12),
                ns[m], i, k, tfos, nucs, stack1, solutions1);

       stack3, solutions3 :=
          P_O3a(tfo_combine(ns[m, 2], T12),
                ns[m], i, k, tfos, nucs, stack2, solutions2)

   while m < array_limh(ns) repeat
       m := old m + 1;

       stack1, solutions1 :=
          P_O3a(tfo_combine(ns[m, 4], T12),
                ns[m], i, k, tfos, nucs, old stack3, old solutions3);

       stack2, solutions2 :=
          P_O3a(tfo_combine(ns[m, 3], T12),
                ns[m], i, k, tfos, nucs, stack1, solutions1);

       stack3, solutions3 :=
          P_O3a(tfo_combine(ns[m, 2], T12),
                ns[m], i, k, tfos, nucs, stack2, solutions2)

   returns value of stack3
           value of solutions3
   end for

end function % P_O3
function pseudoknot_domains(k    : integer;
                            tfos : tfo1;     nucs     : nuc2;
                            stack: solution; solutions: solution1
                    returns solution, solution1)

   if     k = 0 then
    
      reference(tfos[0], nucs[0, 0], 23,     k, tfos, nucs, stack, solutions)

   elseif k = 1 then

      wc_dumas (tfos[2], nucs[3, 0],  8, 23, k, tfos, nucs, stack, solutions)

   elseif k = 2 then

      helix3   (tfos[4], nucs[2, 0], 22, 23, k, tfos, nucs, stack, solutions)

   elseif k = 3 then

      wc_dumas (tfos[2], nucs[1, 0],  9, 22, k, tfos, nucs, stack, solutions)

   elseif k = 4 then

      helix3   (tfos[4], nucs[2, 0], 21, 22, k, tfos, nucs, stack, solutions)

   elseif k = 5 then

      wc_dumas (tfos[2], nucs[1, 0], 10, 21, k, tfos, nucs, stack, solutions)

   elseif k = 6 then

      helix3   (tfos[4], nucs[1, 0], 20, 21, k, tfos, nucs, stack, solutions)

   elseif k = 7 then

      wc_dumas (tfos[2], nucs[2, 0], 11, 20, k, tfos, nucs, stack, solutions)

   elseif k = 8 then

      helix3   (tfos[4], nucs[5, 0], 19, 20, k, tfos, nucs, stack, solutions)

   elseif k = 9 then

      wc_dumas (tfos[2], nucs[0, 0], 12, 19, k, tfos, nucs, stack, solutions)

   elseif k = 10 then

      helix3   (tfos[4], nucs[1, 0],  3, 19, k, tfos, nucs, stack, solutions)

   elseif k = 11 then

      wc_dumas (tfos[2], nucs[2, 0], 13,  3, k, tfos, nucs, stack, solutions)

   elseif k = 12 then

      helix3   (tfos[4], nucs[1, 0],  2,  3, k, tfos, nucs, stack, solutions)

   elseif k = 13 then

      wc_dumas (tfos[2], nucs[2, 0], 14,  2, k, tfos, nucs, stack, solutions)

   elseif k = 14 then

      helix3   (tfos[4], nucs[1, 0],  1,  2, k, tfos, nucs, stack, solutions)

   elseif k = 15 then

      wc_dumas (tfos[2], nucs[4, 0], 15,  1, k, tfos, nucs, stack, solutions)

   elseif k = 16 then

      P_O3(nucs[3], 16, 15, k, tfos, nucs, stack, solutions)

   elseif k = 17 then

      P_O3(nucs[1], 17, 16, k, tfos, nucs, stack, solutions)

   elseif k = 18 then

      P_O3(nucs[0], 18, 17, k, tfos, nucs, stack, solutions)

   elseif k = 19 then

      helix3   (tfos[4], nucs[3, 0],  7,  8, k, tfos, nucs, stack, solutions)

   elseif k = 20 then

      P_O3(nucs[1], 4, 3, k, tfos, nucs, stack, solutions)

   elseif k = 21 then

      let

      stack1, solutions1 :=
      G37_A38  (tfos[5], nucs[3, 0],  5,  4, k, tfos, nucs, stack, solutions)

      in

      helix5   (tfos[3], nucs[3, 0],  5,  4, k, tfos, nucs, stack1, solutions1)

      end let

   elseif k = 22 then

      let

      stack1, solutions1 :=
      G37_A38  (tfos[5], nucs[1, 0],  6,  5, k, tfos, nucs, stack, solutions)

      in

      helix5   (tfos[3], nucs[1, 0],  6,  5, k, tfos, nucs, stack1, solutions1)

      end let

   else

      stack, array_addh(solutions, stack)

   end if

end function % pseudoknot_domains


function var_most_distant_atom(var: var returns double)

   max( for i in 0, (array_size(var.nuc[5]) - 1) / 3
            j       := 3 * i;
            x, y, z := atom_pos(var.nuc[5], j, var.tfo)
        returns value of greatest distance(x, y, z)
        end for,

        for i in 0, (array_size(var.nuc[6]) - 1) / 3
            j       := 3 * i;
            x, y, z := atom_pos(var.nuc[6], j, var.tfo)
        returns value of greatest distance(x, y, z)
        end for
      )

end function % var_most_distant_atom


function most_distant_atom(solutions: solution1 returns double)

   for sol in solutions cross var in sol
   returns value of greatest var_most_distant_atom(var)
   end for

end function % most_distant_atom


function run(tfos: tfo1; nucs: nuc2  returns double)

   let
     stack      := array solution  [];
     solutions  := array solution1 [];

     stack1,
     solutions1 := pseudoknot_domains( 0, tfos, nucs, stack, solutions)
   in
     most_distant_atom( solutions1)
   end let

end function % run


function main (	returns double)

   run( init_tfo(), init_nucleotides() )

end function % main


