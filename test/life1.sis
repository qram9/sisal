% John Conway's Game of Life.  Values of the Grid are 0's or 1's.  A given
% cell has 8 neighbors.  One each iteration updates cells as follows:
%  -- If a cell contains a 1 and greater than five of its neighbors contain
%     1's, then it should be updated to a 0.
%  -- If a cell contains a 0 and has more than three or fewer then three 
%     neighbors containing 1's, then it should be updated to a 1
%  -- otherwise the value of a cell remains unchanged.
% The simulation of life iterates Num times. The boarder of the grid is
% initialized to zeros.

% Program Input: Iterations, Rows, Columns, Grid

define Main

type   OneDim  = array[integer];
type     Grid  = array[OneDim];

function Compute( G : Grid; I : integer; J : integer returns integer )
    let
        Total := G[I+1,J-1] + G[I+1,J] + G[I+1,J+1] + 
	         G[I-1,J-1] + G[I-1,J] + G[I-1,J+1] +
                 G[I,J-1]   + G[I,J+1];
    in
        if ( G[I,J] = 1 & Total > 5 ) then 0 
	ELSEIF ( Total ~= 3 ) then 1 else 0 end if
    end let
end function

function DoWork( G : Grid; Rows, Columns : integer returns Grid )
    let
	Clast  := Columns + 1;
	Rlast  := Rows    + 1;
	Middle := for I in 1, Rows
		      Mid := for J in 1, Columns
				 V := Compute( G, I, J );
			     returns array of V
			     end for;
                      Row := array_addl( Mid, G[I,0] );
                  returns array of array_addh( Row, G[I,Clast] )
		  end for;
    in
	array_addl( array_addh( Middle, G[Rlast] ), G[0] )
    end let
end function

function Main( Num, Rows, Columns : integer; G : Grid returns Grid )
    for initial
	Count := Num;
	NewG  := G
    while ( Count > 0 ) repeat
	Count := old Count - 1;
	NewG  := DoWork( old NewG, Rows, Columns ); 
    returns value of NewG
    end for
end function
